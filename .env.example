# Server
PORT=3000
RATE_LIMIT_PER_MINUTE=60

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/wandersync

# Redis
REDIS_URL=redis://localhost:6379

# Auth (ADR-004: stateless JWT, bcrypt)
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRY=86400

# External APIs — Active (required for prototype)
AVIATIONSTACK_API_KEY=
OWM_API_KEY=
GEMINI_API_KEY=

# External APIs — Future (fill when promoting provider to ACTIVE)
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AIRLABS_API_KEY=
TOMORROW_IO_API_KEY=
BOOKING_COM_AFFILIATE_ID=
UBER_CLIENT_ID=
UBER_CLIENT_SECRET=
RAPIDAPI_KEY=
